{
  "name": "@okx_ai/okx-trade-mcp",
  "version": "1.2.8-beta.4",
  "description": "OKX MCP Server - Model Context Protocol server for OKX exchange",
  "type": "module",
  "license": "MIT",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "okx-trade-mcp": "dist/index.js"
  },
  "files": ["dist", "scripts", "README.md"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsup && node -e \"const fs=require('fs');fs.mkdirSync('scripts',{recursive:true});fs.copyFileSync('../../scripts/postinstall-notice.js','scripts/postinstall.js')\"",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist scripts",
    "postinstall": "node scripts/postinstall.js || exit 0",
    "test:unit": "node --import tsx/esm --test test/*.test.ts"
  },
  "engines": { "node": ">=18" },
  "keywords": ["okx", "mcp", "model-context-protocol", "trading"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "smol-toml": "^1.3.4",
    "undici": "^6.0.0"
  },
  "devDependencies": {
    "@agent-tradekit/core": "file:../core",
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3"
  }
}
