  },
  "engines": { "node": ">=18" },
  "keywords": ["okx", "mcp", "model-context-protocol", "trading"],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0"
  },
  "devDependencies": {
    "@agent-tradekit/core": "workspace:*",
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
