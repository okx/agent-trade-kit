{
  "name": "@agent-tradekit/core",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "test:unit": "node --import tsx/esm --test --test-reporter=spec test/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text --src=src node --import tsx/esm --test test/*.test.ts"
  },
  "dependencies": {
    "smol-toml": "^1.3.4",
    "undici": "^6.0.0",
    "yauzl": "^3.2.1"
  },
  "devDependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "@types/node": "^25.2.2",
    "@types/yauzl": "^2.10.3",
    "@types/yazl": "^3.3.0",
    "c8": "^10.1.3",
    "tsup": "^8.5.1",
    "tsx": "^4.19.3",
    "typescript": "^5.9.3",
    "yazl": "^3.3.1"
  }
}
