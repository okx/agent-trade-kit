{
  "name": "okx-hub",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "build": "pnpm --filter @okx-hub/core build && pnpm --filter okx-trade-mcp build && pnpm --filter okx-trade-cli build",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "test:unit": "pnpm --filter @okx-hub/core test:unit"
  },
  "engines": {
    "node": ">=18",
    "pnpm": ">=9"
  },
  "devDependencies": {
    "@types/node": "^25.2.2",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3"
  }
}
